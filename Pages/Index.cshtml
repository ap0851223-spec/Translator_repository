@page
@model Project_translator.Pages.IndexModel
@{
    ViewData["Title"] = "🌐 Универсальный Переводчик";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css">

    <style>
        :root {
            --primary: #4361ee;
            --secondary: #3a0ca3;
            --success: #4cc9f0;
            --danger: #f72585;
            --gradient: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
        }

        body {
            background: linear-gradient(270deg, #2c3e50, #34495e, #2c3e50, #3b5998);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            min-height: 100vh;
            padding: 20px 0;
            font-family: 'Segoe UI', sans-serif;
        }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            25% {
                background-position: 100% 0%;
            }

            50% {
                background-position: 100% 100%;
            }

            75% {
                background-position: 0% 100%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        body::before {
            content: '';
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: radial-gradient(circle at 20% 50%, rgba(67, 97, 238, 0.05) 0%, transparent 50%), radial-gradient(circle at 80% 20%, rgba(76, 201, 240, 0.05) 0%, transparent 50%), radial-gradient(circle at 50% 80%, rgba(247, 37, 133, 0.03) 0%, transparent 50%);
            pointer-events: none;
            z-index: 0;
        }

        .container {
            position: relative;
            z-index: 1;
        }

        .main-title {
            color: white;
            text-shadow: 0 2px 10px rgba(0,0,0,0.3);
            font-weight: 700;
            font-size: 2.2rem;
            animation: fadeInDown 0.8s ease;
        }

        .subtitle {
            color: rgba(255,255,255,0.8);
            animation: fadeIn 1s ease;
        }

        .main-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.3);
            overflow: hidden;
            animation: fadeInUp 0.6s ease;
        }

        .card-header-custom {
            background: linear-gradient(135deg, var(--primary) 0%, var(--secondary) 100%);
            color: white;
            padding: 1.2rem 1.5rem;
            font-weight: 600;
        }

        .translation-input {
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 1.1rem;
            transition: all 0.3s ease;
            resize: vertical;
            min-height: 80px;
        }

            .translation-input:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.15);
            }

        .mic-btn {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: 2px solid #e0e0e0;
            background: white;
            color: #666;
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
        }

            .mic-btn:hover {
                background: #f0f0f0;
                border-color: var(--primary);
                color: var(--primary);
            }

            .mic-btn.recording {
                background: var(--danger);
                color: white;
                border-color: var(--danger);
                animation: pulse-record 1.5s infinite;
            }

        @@keyframes pulse-record {
            0%, 100% {
                box-shadow: 0 0 0 0 rgba(247, 37, 133, 0.5);
            }

            50% {
                box-shadow: 0 0 0 15px rgba(247, 37, 133, 0);
            }
        }

        .lang-select {
            height: 50px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 1rem;
            transition: all 0.3s ease;
        }

            .lang-select:focus {
                border-color: var(--primary);
                box-shadow: 0 0 0 0.25rem rgba(67, 97, 238, 0.15);
            }

        .swap-btn {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            border: 2px solid #e0e0e0;
            background: white;
            color: var(--primary);
            font-size: 1.2rem;
            cursor: pointer;
            transition: all 0.3s ease;
        }

            .swap-btn:hover {
                background: var(--primary);
                color: white;
                border-color: var(--primary);
                transform: rotate(180deg);
            }

        .translate-btn {
            background: var(--gradient);
            border: none;
            color: white;
            font-weight: 600;
            font-size: 1.1rem;
            padding: 12px;
            border-radius: 50px;
            transition: all 0.3s ease;
            box-shadow: 0 4px 15px rgba(67, 97, 238, 0.4);
        }

            .translate-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 20px rgba(67, 97, 238, 0.5);
            }

            .translate-btn:disabled {
                opacity: 0.7;
                transform: none;
            }

        .result-box {
            min-height: 100px;
            border: 2px dashed #e0e0e0;
            border-radius: 12px;
            padding: 1rem;
            transition: all 0.5s ease;
        }

            .result-box.has-result {
                border-color: #28a745;
                background: linear-gradient(135deg, #f8fff9 0%, #e8f5e9 100%);
                animation: resultPop 0.4s ease;
            }

        @@keyframes resultPop {
            0% {
                transform: scale(0.98);
                opacity: 0.5;
            }

            50% {
                transform: scale(1.01);
            }

            100% {
                transform: scale(1);
                opacity: 1;
            }
        }

        .action-btn {
            border-radius: 50px;
            padding: 8px 20px;
            font-weight: 500;
            transition: all 0.3s ease;
        }

            .action-btn:hover {
                transform: translateY(-2px);
            }

        .history-card {
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.2);
            overflow: hidden;
            animation: fadeInRight 0.6s ease;
        }

        .history-item {
            cursor: pointer;
            padding: 10px 15px;
            border-left: 3px solid transparent;
            transition: all 0.3s ease;
        }

            .history-item:hover {
                background: #f8f9ff;
                border-left-color: var(--primary);
                transform: translateX(5px);
            }

        @@keyframes fadeInDown {
            from {
                opacity: 0;
                transform: translateY(-30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeInRight {
            from {
                opacity: 0;
                transform: translateX(30px);
            }

            to {
                opacity: 1;
                transform: translateX(0);
            }
        }

        @@keyframes fadeIn {
            from {
                opacity: 0;
            }

            to {
                opacity: 1;
            }
        }

        .spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,0.3);
            border-top-color: white;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }

        @@keyframes spin {
            to {
                transform: rotate(360deg);
            }
        }

        .loading-dots {
            display: flex;
            gap: 6px;
            justify-content: center;
            padding: 20px;
        }

            .loading-dots span {
                width: 10px;
                height: 10px;
                border-radius: 50%;
                background: var(--primary);
                animation: bounce 1.2s ease-in-out infinite;
            }

                .loading-dots span:nth-child(2) {
                    animation-delay: 0.2s;
                }

                .loading-dots span:nth-child(3) {
                    animation-delay: 0.4s;
                }

        @@keyframes bounce {
            0%, 60%, 100% {
                transform: translateY(0);
                opacity: 0.5;
            }

            30% {
                transform: translateY(-15px);
                opacity: 1;
            }
        }

        .toast-notification {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            animation: slideDown 0.3s ease;
        }

        @@keyframes slideDown {
            from {
                opacity: 0;
                transform: translate(-50%, -20px);
            }

            to {
                opacity: 1;
                transform: translate(-50%, 0);
            }
        }

        .lang-badge {
            display: inline-block;
            padding: 4px 12px;
            border-radius: 20px;
            font-size: 0.85em;
            font-weight: 600;
        }

        .badge-source {
            background: #e8ecff;
            color: var(--primary);
        }

        .badge-target {
            background: #e8f5e9;
            color: #28a745;
        }

        @@media (max-width: 768px) {
            .main-title {
                font-size: 1.6rem;
            }

            .container {
                padding: 10px;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <!-- Заголовок -->
        <div class="text-center mb-4">
            <h1 class="main-title">
                <i class="bi bi-translate me-2"></i>Универсальный Переводчик
            </h1>
            <p class="subtitle">
                <i class="bi bi-mic me-1"></i>Голос •
                <i class="bi bi-volume-up me-1"></i>Озвучка •
                <i class="bi bi-globe2 me-1"></i>8 языков
            </p>
            <a href="/WebsiteTranslator" class="btn btn-outline-light mt-2">
                <i class="bi bi-globe me-2"></i>Перевести сайт
                <span class="badge bg-light text-dark ms-2">NEW</span>
            </a>
        </div>

        <div class="row">
            <!-- Основной блок -->
            <div class="col-lg-8 mb-4">
                <div class="main-card">
                    <div class="card-header-custom">
                        <div class="d-flex justify-content-between align-items-center">
                            <h5 class="mb-0"><i class="bi bi-chat-left-text me-2"></i>Переводчик</h5>
                            <span id="apiBadge" class="badge bg-light text-primary">
                                <i class="bi bi-check-circle me-1"></i>API онлайн
                            </span>
                        </div>
                    </div>

                    <div class="card-body p-4">
                        <!-- Поле ввода -->
                        <div class="mb-3">
                            <label class="form-label fw-bold small text-muted">
                                <i class="bi bi-pencil me-1"></i>Текст для перевода:
                            </label>
                            <div class="input-group">
                                <textarea id="sourceText" class="form-control translation-input"
                                          rows="3" placeholder="Введите текст или нажмите 🎤..."></textarea>
                                <button id="micBtn" class="mic-btn ms-2" title="Голосовой ввод">
                                    <i class="bi bi-mic"></i>
                                </button>
                            </div>
                            <div id="recordingStatus" style="display: none;" class="text-danger small mt-1">
                                <i class="bi bi-record-circle"></i> Говорите...
                            </div>
                        </div>

                        <!-- Языки -->
                        <div class="row mb-3 align-items-end">
                            <div class="col-5">
                                <label class="form-label fw-bold small text-muted">С какого языка:</label>
                                <select id="sourceLang" class="form-select lang-select">
                                    <option value="auto">🌍 Авто</option>
                                    <option value="ru">🇷🇺 Русский</option>
                                    <option value="en">🇬🇧 English</option>
                                    <option value="tt">🇹🇹 Татарский</option>
                                    <option value="es">🇪🇸 Español</option>
                                    <option value="fr">🇫🇷 Français</option>
                                    <option value="de">🇩🇪 Deutsch</option>
                                    <option value="tr">🇹🇷 Türkçe</option>
                                    <option value="zh">🇨🇳 中文</option>
                                </select>
                            </div>
                            <div class="col-2 text-center pb-1">
                                <button id="swapBtn" class="swap-btn" title="Поменять языки">
                                    <i class="bi bi-arrow-left-right"></i>
                                </button>
                            </div>
                            <div class="col-5">
                                <label class="form-label fw-bold small text-muted">На какой язык:</label>
                                <select id="targetLang" class="form-select lang-select">
                                    <option value="en">🇬🇧 English</option>
                                    <option value="ru" selected>🇷🇺 Русский</option>
                                    <option value="tt">🇹🇹 Татарский</option>
                                    <option value="es">🇪🇸 Español</option>
                                    <option value="fr">🇫🇷 Français</option>
                                    <option value="de">🇩🇪 Deutsch</option>
                                    <option value="tr">🇹🇷 Türkçe</option>
                                    <option value="zh">🇨🇳 中文</option>
                                </select>
                            </div>
                        </div>

                        <!-- Кнопка перевода -->
                        <button id="translateBtn" class="btn translate-btn w-100 mb-3">
                            <i class="bi bi-arrow-repeat me-2"></i>
                            <span id="translateBtnText">Перевести</span>
                            <span id="translateSpinner" class="spinner ms-2" style="display: none;"></span>
                        </button>
                        <div class="text-center">
                            <small class="text-muted">
                                <kbd>Ctrl+Enter</kbd> — перевести | <kbd>Ctrl+Space</kbd> — голос
                            </small>
                        </div>

                        <!-- Результат -->
                        <div id="resultBox" class="result-box mt-3">
                            <div class="text-center text-muted py-3">
                                <i class="bi bi-translate fs-3 mb-2 d-block"></i>
                                <span>Здесь появится перевод</span>
                            </div>
                        </div>

                        <!-- Кнопки действий -->
                        <div id="actionButtons" class="d-flex gap-2 mt-3" style="display: none !important;">
                            <button id="speakBtn" class="btn btn-success action-btn">
                                <i class="bi bi-volume-up me-1"></i> Озвучить
                            </button>
                            <button id="copyBtn" class="btn btn-outline-secondary action-btn">
                                <i class="bi bi-clipboard me-1"></i> Копировать
                            </button>
                            <button id="clearBtn" class="btn btn-outline-danger action-btn ms-auto">
                                <i class="bi bi-eraser me-1"></i> Очистить
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <!-- История -->
            <!-- Боковая панель -->
            <div class="col-lg-4">
                <!-- История -->
                <div class="history-card mb-3">
                    <div class="card-header-custom" style="background: linear-gradient(135deg, #4cc9f0 0%, #4361ee 100%);">
                        <h6 class="mb-0"><i class="bi bi-clock-history me-2"></i>История</h6>
                    </div>
                    <div id="historyList" style="max-height: 300px; overflow-y: auto;">
                        <div class="text-center text-muted py-4">
                            <i class="bi bi-hourglass fs-3 mb-2 d-block"></i>
                            <small>Пока пусто</small>
                        </div>
                    </div>
                </div>

                <!-- Культурный профиль -->
                <div class="history-card">
                    <div class="card-header-custom" style="background: linear-gradient(135deg, #f72585 0%, #b5179e 100%);">
                        <h6 class="mb-0"><i class="bi bi-globe2 me-2"></i>Культурный профиль</h6>
                    </div>
                    <div id="culturalProfile" class="p-3">
                        <div class="text-center text-muted py-3">
                            <i class="bi bi-info-circle fs-3 mb-2 d-block"></i>
                            <small>Выберите язык для просмотра культурных особенностей</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Поддерживаемые языки -->
        <div class="text-center mt-3">
            <div class="d-flex flex-wrap justify-content-center gap-2">
                <span class="badge bg-primary">🇷🇺 RU</span>
                <span class="badge bg-info">🇬🇧 EN</span>
                <span class="badge bg-warning text-dark">🇹🇹 TT</span>
                <span class="badge bg-danger">🇪🇸 ES</span>
                <span class="badge bg-secondary">🇫🇷 FR</span>
                <span class="badge bg-dark">🇩🇪 DE</span>
                <span class="badge bg-success">🇹🇷 TR</span>
                <span class="badge bg-danger">🇨🇳 ZH</span>
            </div>
        </div>
    </div>

    <script>
        let recognition = null;
        let isRecording = false;
        let currentResult = null;

        document.addEventListener('DOMContentLoaded', () => {
            console.log('🌟 Переводчик загружен');
            initVoice();
            bindEvents();
            checkApi();
            loadHistory();

            // setTimeout(() => {
            //     document.getElementById('sourceText').value = 'Hello! How are you?';
            //     document.getElementById('sourceLang').value = 'en';
            //     document.getElementById('targetLang').value = 'ru';
            //     translate();
            // }, 500);
        });

        function initVoice() {
            const SpeechRecognition = window.SpeechRecognition || window.webkitSpeechRecognition;
            if (SpeechRecognition) {
                recognition = new SpeechRecognition();
                recognition.continuous = false;
                recognition.interimResults = false;

                recognition.onstart = () => {
                    isRecording = true;
                    document.getElementById('micBtn').classList.add('recording');
                    document.getElementById('micBtn').querySelector('i').className = 'bi bi-record-circle';
                    document.getElementById('recordingStatus').style.display = 'block';
                };

                recognition.onresult = (e) => {
                    const text = e.results[0][0].transcript;
                    document.getElementById('sourceText').value = text;
                    document.getElementById('sourceLang').value = 'auto';
                    stopRecording();
                    setTimeout(translate, 300);
                };

                recognition.onerror = (e) => {
                    stopRecording();
                    toast('Ошибка микрофона: ' + e.error, 'danger');
                };

                recognition.onend = stopRecording;
            } else {
                document.getElementById('micBtn').style.display = 'none';
            }
        }

        function startRecording() {
            if (recognition) {
                try {
                    const langMap = {
                        'ru': 'ru-RU', 'en': 'en-US', 'tt': 'ru-RU',
                        'es': 'es-ES', 'fr': 'fr-FR', 'de': 'de-DE',
                        'tr': 'tr-TR', 'zh': 'zh-CN', 'auto': 'en-US'
                    };
                    recognition.lang = langMap[document.getElementById('sourceLang').value] || 'en-US';
                    recognition.start();
                } catch (e) {
                    toast('Ошибка запуска микрофона', 'danger');
                }
            }
        }

        function stopRecording() {
            isRecording = false;
            const btn = document.getElementById('micBtn');
            btn.classList.remove('recording');
            btn.querySelector('i').className = 'bi bi-mic';
            document.getElementById('recordingStatus').style.display = 'none';
        }

        async function translate() {
            const text = document.getElementById('sourceText').value.trim();
            const source = document.getElementById('sourceLang').value;
            const target = document.getElementById('targetLang').value;

            if (!text) {
                toast('Введите текст для перевода', 'warning');
                return;
            }

            document.getElementById('resultBox').innerHTML = `
                <div class="loading-dots">
                    <span></span><span></span><span></span>
                </div>
                <p class="text-center text-muted small mt-2">Переводим...</p>
            `;
            document.getElementById('resultBox').classList.remove('has-result');

            document.getElementById('translateSpinner').style.display = 'inline-block';
            document.getElementById('translateBtn').disabled = true;
            document.getElementById('translateBtnText').textContent = 'Переводим...';

            try {
                const res = await fetch('/api/QuickTranslate/translate', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ Text: text, SourceLang: source, TargetLang: target })
                });
                const data = await res.json();

                if (data.success) {
                    currentResult = data;
                    showResult(data);
                    document.getElementById('actionButtons').style.display = 'flex';
                    setTimeout(loadHistory, 500);
                } else {
                    document.getElementById('resultBox').innerHTML = `
                        <div class="text-center text-danger py-3">
                            <i class="bi bi-exclamation-triangle fs-3 mb-2 d-block"></i>
                            <span>${data.error || 'Ошибка перевода'}</span>
                        </div>
                    `;
                }
            } catch (e) {
                document.getElementById('resultBox').innerHTML = `
                    <div class="text-center text-danger py-3">
                        <i class="bi bi-wifi-off fs-3 mb-2 d-block"></i>
                        <span>Ошибка соединения</span>
                    </div>
                `;
            } finally {
                document.getElementById('translateSpinner').style.display = 'none';
                document.getElementById('translateBtn').disabled = false;
                document.getElementById('translateBtnText').textContent = 'Перевести';
            }
        }

        function showResult(data) {
            document.getElementById('resultBox').innerHTML = `
                <div class="mb-2">
                    <span class="lang-badge badge-source">${data.source.toUpperCase()}</span>
                    <small class="text-muted ms-2">Исходный текст:</small>
                    <div class="p-2 bg-light rounded mt-1">${escapeHtml(data.original)}</div>
                </div>
                <div>
                    <span class="lang-badge badge-target">${data.target.toUpperCase()}</span>
                    <small class="text-muted ms-2">Перевод:</small>
                    <div class="p-2 bg-success bg-opacity-10 rounded mt-1 fw-bold">${escapeHtml(data.translated)}</div>
                </div>
            `;
            document.getElementById('resultBox').classList.add('has-result');
            document.getElementById('actionButtons').style.display = 'flex';
        }

        function speak() {
            if (!currentResult || !('speechSynthesis' in window)) return;
            window.speechSynthesis.cancel();
            const u = new SpeechSynthesisUtterance(currentResult.translated);
            const langMap = {
                'ru': 'ru-RU', 'en': 'en-US', 'es': 'es-ES',
                'fr': 'fr-FR', 'de': 'de-DE', 'tr': 'tr-TR',
                'zh': 'zh-CN', 'tt': 'ru-RU'
            };
            u.lang = langMap[currentResult.target] || 'en-US';
            u.rate = ['tt', 'tr'].includes(currentResult.target) ? 0.8 : 1.0;
            const voices = window.speechSynthesis.getVoices();
            const voice = voices.find(v => v.lang.startsWith(u.lang.split('-')[0]));
            if (voice) u.voice = voice;
            window.speechSynthesis.speak(u);
            toast('🔊 Озвучиваю...', 'info');
        }

        function copyResult() {
            if (!currentResult) return;
            navigator.clipboard.writeText(currentResult.translated).then(() => {
                toast('✅ Скопировано!', 'success');
            });
        }

        function clearAll() {
            document.getElementById('sourceText').value = '';
            document.getElementById('resultBox').innerHTML = `
                <div class="text-center text-muted py-3">
                    <i class="bi bi-translate fs-3 mb-2 d-block"></i>
                    <span>Здесь появится перевод</span>
                </div>
            `;
            document.getElementById('resultBox').classList.remove('has-result');
            document.getElementById('actionButtons').style.display = 'none';
            currentResult = null;
        }

        async function loadHistory() {
            try {
                const res = await fetch('/api/TranslationMemory/history?limit=10');
                const data = await res.json();
                if (data.success && data.history.length > 0) {
                    document.getElementById('historyList').innerHTML = data.history.map(item => `
                        <div class="history-item border-bottom" onclick="useHistory('${escapeAttr(item.sourceText)}', '${escapeAttr(item.sourceLang)}', '${escapeAttr(item.targetLang)}')">
                            <div class="small text-muted">${escapeHtml(item.sourceText).substring(0, 30)}...</div>
                            <div class="fw-bold small">${escapeHtml(item.targetText).substring(0, 30)}...</div>
                            <div class="d-flex justify-content-between">
                                <small class="text-muted">${item.sourceLang} → ${item.targetLang}</small>
                                <small class="text-muted">×${item.usageCount}</small>
                            </div>
                        </div>
                    `).join('');
                }
            } catch (e) {}
        }

        function useHistory(text, source, target) {
            document.getElementById('sourceText').value = text;
            document.getElementById('sourceLang').value = source;
            document.getElementById('targetLang').value = target;
            translate();
        }

        async function loadCulturalProfile(langCode) {
            try {
                const res = await fetch(`/api/CulturalAdaptation/profile/${langCode}`);
                if (res.ok) {
                    const data = await res.json();
                    document.getElementById('culturalProfile').innerHTML = `
                        <h6>🌍 ${data.localeName}</h6>
                        <p class="small mb-1">💰 Валюта: ${data.currency}</p>
                        <p class="small mb-1">📅 Дата: ${data.examples.date}</p>
                        <p class="small mb-1">🕐 Время: ${data.examples.time}</p>
                        <hr class="my-2">
                        ${data.culturalNotes.map(n => `<p class="small mb-1">${n}</p>`).join('')}
                    `;
                }
            } catch (e) {}
        }

        function bindEvents() {
            document.getElementById('translateBtn').addEventListener('click', translate);
            document.getElementById('speakBtn').addEventListener('click', speak);
            document.getElementById('copyBtn').addEventListener('click', copyResult);
            document.getElementById('clearBtn').addEventListener('click', clearAll);

            document.getElementById('micBtn').addEventListener('click', () => {
                isRecording ? stopRecording() : startRecording();
            });

            document.getElementById('swapBtn').addEventListener('click', () => {
                const s = document.getElementById('sourceLang');
                const t = document.getElementById('targetLang');
                if (s.value === 'auto') {
                    toast('Нельзя обменять автоопределение', 'warning');
                    return;
                }
                [s.value, t.value] = [t.value, s.value];
                document.getElementById('swapBtn').style.transform = 'rotate(180deg)';
                setTimeout(() => document.getElementById('swapBtn').style.transform = '', 300);
                loadHistory();
                loadCulturalProfile(t.value);
            });

            document.addEventListener('keydown', e => {
                if (e.ctrlKey && e.key === 'Enter') { e.preventDefault(); translate(); }
                if (e.ctrlKey && e.code === 'Space') { e.preventDefault();
                    document.getElementById('micBtn').click(); }
            });

            document.getElementById('sourceLang').addEventListener('change', loadHistory);

            document.getElementById('targetLang').addEventListener('change', function() {
                loadHistory();
                loadCulturalProfile(this.value);
            });
        }

        async function checkApi() {
            try {
                const res = await fetch('/api/QuickTranslate/status');
                if (res.ok) {
                    const data = await res.json();
                    if (data.status === 'online') {
                        document.getElementById('apiBadge').className = 'badge bg-success';
                        document.getElementById('apiBadge').innerHTML = '<i class="bi bi-check-circle me-1"></i>API онлайн';
                    }
                }
            } catch (e) {
                console.log('API status check failed, but translation may still work');
            }
        }

        function toast(msg, type = 'info') {
            const div = document.createElement('div');
            div.className = `toast-notification alert alert-${type} py-2 px-4`;
            div.textContent = msg;
            document.body.appendChild(div);
            setTimeout(() => {
                div.style.opacity = '0';
                div.style.transition = 'opacity 0.3s';
                setTimeout(() => div.remove(), 300);
            }, 2500);
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        function escapeAttr(text) {
            return text?.replace(/'/g, "\\'").replace(/"/g, '&quot;') || '';
        }
                // ===== КУЛЬТУРНЫЙ ПРОФИЛЬ =====
        async function loadCulturalProfile(langCode) {
            try {
                const res = await fetch(`/api/CulturalAdaptation/profile/${langCode}`);
                if (res.ok) {
                    const data = await res.json();
                    const info = data.languageInfo;

                    document.getElementById('culturalProfile').innerHTML = `
                        <h5>🌍 ${info.languageName} (${info.nativeName})</h5>

                        <p class="small mb-1"><strong>🌏 Страны:</strong></p>
                        <div class="mb-2">
                            ${info.countries.map(c => `<span class="badge bg-light text-dark me-1 mb-1">${c}</span>`).join('')}
                        </div>

                        <p class="small mb-1"><strong>📍 Регионы:</strong> ${info.regions.join(', ')}</p>
                        <p class="small mb-1"><strong>👥 Носителей:</strong> ${info.nativeSpeakers}</p>
                        <p class="small mb-1"><strong>🗣 Всего говорящих:</strong> ${info.totalSpeakers}</p>
                        <p class="small mb-1"><strong>📜 Семья:</strong> ${info.languageFamily}</p>
                        <p class="small mb-1"><strong>✍️ Письменность:</strong> ${info.writingSystem}</p>
                        <p class="small mb-1"><strong>🏛 Официальный в:</strong> ${info.isOfficialIn.join(', ')}</p>

                        <hr class="my-2">
                        <p class="small mb-1"><strong>💰 Валюта:</strong> ${info.currencyName} (${info.currencySymbol})</p>
                        <p class="small mb-1"><strong>📅 Формат даты:</strong> ${info.dateFormatDescription}</p>
                        <p class="small mb-1"><strong>🕐 Формат времени:</strong> ${info.timeFormatDescription}</p>

                        <hr class="my-2">
                        <p class="small mb-1"><strong>💡 Интересные факты:</strong></p>
                        ${info.interestingFacts.map(f => `<p class="small mb-1">• ${f}</p>`).join('')}
                    `;
                }
            } catch (e) {
                console.log('Культурный профиль недоступен');
            }
        }

        function escapeAttr(text) {
            return text?.replace(/'/g, "\\'").replace(/"/g, '&quot;') || '';
        }
    </script>
    </script>
</body>
</html>