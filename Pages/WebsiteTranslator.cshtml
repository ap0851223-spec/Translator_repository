@page
@model Project_translator.Pages.WebsiteTranslatorModel
@{
    ViewData["Title"] = "🌐 Перевод сайтов";
}

<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <title>@ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">

    <style>
        :root {
            --primary: #2c3e50;
            --secondary: #34495e;
            --accent: #3498db;
        }

        body {
            background: linear-gradient(270deg, #1a1a2e, #16213e, #1a1a2e, #0f3460);
            background-size: 400% 400%;
            animation: gradientShift 15s ease infinite;
            min-height: 100vh;
            font-family: 'Segoe UI', sans-serif;
            color: #ecf0f1;
        }

        @@keyframes gradientShift {
            0% {
                background-position: 0% 50%;
            }

            50% {
                background-position: 100% 50%;
            }

            100% {
                background-position: 0% 50%;
            }
        }

        .main-card {
            background: rgba(44, 62, 80, 0.95);
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        .url-input {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            border-radius: 12px;
            padding: 15px;
            font-size: 1.1rem;
        }

            .url-input:focus {
                background: rgba(255,255,255,0.15);
                border-color: #3498db;
                color: white;
                box-shadow: 0 0 0 0.25rem rgba(52, 152, 219, 0.25);
            }

            .url-input::placeholder {
                color: rgba(255,255,255,0.5);
            }

        .lang-card {
            background: rgba(255,255,255,0.05);
            border: 2px solid rgba(255,255,255,0.1);
            border-radius: 12px;
            padding: 15px;
            cursor: pointer;
            transition: all 0.3s ease;
            text-align: center;
        }

            .lang-card:hover {
                background: rgba(255,255,255,0.1);
                border-color: #3498db;
                transform: translateY(-3px);
                box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            }

            .lang-card.selected {
                border-color: #3498db;
                background: rgba(52, 152, 219, 0.2);
                box-shadow: 0 0 20px rgba(52, 152, 219, 0.3);
            }

        .lang-flag {
            font-size: 2.5rem;
            display: block;
            margin-bottom: 8px;
        }

        .lang-name {
            font-weight: 600;
            font-size: 0.9rem;
            color: white;
        }

        .btn-translate {
            background: linear-gradient(135deg, #3498db, #2980b9);
            border: none;
            color: white;
            font-weight: 600;
            padding: 15px 40px;
            border-radius: 50px;
            font-size: 1.2rem;
            transition: all 0.3s ease;
            box-shadow: 0 4px 20px rgba(52, 152, 219, 0.4);
        }

            .btn-translate:hover {
                transform: translateY(-3px);
                box-shadow: 0 8px 30px rgba(52, 152, 219, 0.6);
            }

        .btn-back {
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            transition: all 0.3s ease;
            font-size: 1.1rem;
        }

            .btn-back:hover {
                color: white;
            }

        .result-box {
            background: rgba(255,255,255,0.1);
            border: 1px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            padding: 25px;
        }

        /* ВСЕ ТЕКСТОВЫЕ ЭЛЕМЕНТЫ БЕЛЫЕ */
        .form-label {
            color: white !important;
            font-weight: 500;
        }

        h3, h4, h5, h6 {
            color: white !important;
        }

        p {
            color: rgba(255, 255, 255, 0.9);
        }

        .text-muted {
            color: rgba(255, 255, 255, 0.75) !important;
        }

        small {
            color: rgba(255, 255, 255, 0.7);
        }

        .badge {
            color: #2c3e50;
        }

        @@media (max-width: 768px) {
            .lang-flag {
                font-size: 1.8rem;
            }

            .btn-translate {
                padding: 12px 25px;
                font-size: 1rem;
            }
        }
    </style>
</head>
<body>
    <div class="container py-4">
        <!-- Навигация -->
        <div class="d-flex justify-content-between align-items-center mb-4">
            <a href="/" class="btn-back">
                <i class="bi bi-arrow-left me-2"></i>← На главную
            </a>
            <span class="badge bg-light text-dark">
                <i class="bi bi-globe2 me-1"></i> Website Translator
            </span>
        </div>

        <div class="main-card p-4">
            <h3 class="text-center mb-3">
                <i class="bi bi-globe me-2"></i>Перевод сайтов
            </h3>
            <p class="text-center mb-4" style="color: rgba(255,255,255,0.85);">
                Введите URL любого сайта, выберите язык и получите переведённую версию
            </p>

            <!-- Поле URL -->
            <div class="mb-4">
                <label class="form-label">
                    <i class="bi bi-link-45deg me-1"></i>URL сайта:
                </label>
                <div class="input-group">
                    <span class="input-group-text" style="background: rgba(255,255,255,0.1); border-color: rgba(255,255,255,0.2); color: white;">
                        <i class="bi bi-globe"></i>
                    </span>
                    <input type="url" id="websiteUrl" class="form-control url-input"
                           placeholder="https://example.com" value="">
                </div>
            </div>

            <!-- Выбор языка -->
            <div class="mb-4">
                <label class="form-label">
                    <i class="bi bi-translate me-1"></i>Перевести на:
                </label>
                <div class="row g-3" id="languageGrid">
                    <!-- Заполняется JavaScript -->
                </div>
            </div>

            <!-- Кнопка -->
            <div class="text-center mb-4">
                <button id="translateWebsiteBtn" class="btn btn-translate">
                    <i class="bi bi-rocket-takeoff me-2"></i>Перевести сайт
                </button>
            </div>

            <!-- Результат -->
            <div id="resultContainer" style="display: none;">
                <!-- Заполняется JavaScript -->
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        const languages = [
            { code: 'ru', flag: '🇷🇺', name: 'Русский' },
            { code: 'en', flag: '🇬🇧', name: 'English' },
            { code: 'tt', flag: '🇹🇹', name: 'Татарский' },
            { code: 'es', flag: '🇪🇸', name: 'Español' },
            { code: 'fr', flag: '🇫🇷', name: 'Français' },
            { code: 'de', flag: '🇩🇪', name: 'Deutsch' },
            { code: 'tr', flag: '🇹🇷', name: 'Türkçe' },
            { code: 'zh', flag: '🇨🇳', name: '中文' }
        ];

        let selectedLanguage = 'ru';

        function renderLanguages() {
            const grid = document.getElementById('languageGrid');
            grid.innerHTML = languages.map(lang => `
                <div class="col-3 col-md-3">
                    <div class="lang-card ${lang.code === selectedLanguage ? 'selected' : ''}"
                         onclick="selectLanguage('${lang.code}')">
                        <span class="lang-flag">${lang.flag}</span>
                        <span class="lang-name">${lang.name}</span>
                    </div>
                </div>
            `).join('');
        }

        function selectLanguage(code) {
            selectedLanguage = code;
            renderLanguages();
        }

        function getTranslatedUrl(url, langCode) {
            return `https://translate.google.com/translate?hl=${langCode}&sl=auto&tl=${langCode}&u=${encodeURIComponent(url)}`;
        }

        document.getElementById('translateWebsiteBtn').addEventListener('click', function() {
            const url = document.getElementById('websiteUrl').value.trim();

            if (!url) {
                alert('Введите URL сайта');
                return;
            }

            let fullUrl = url;
            if (!fullUrl.startsWith('http://') && !fullUrl.startsWith('https://')) {
                fullUrl = 'https://' + fullUrl;
            }

            const translatedUrl = getTranslatedUrl(fullUrl, selectedLanguage);
            const langName = languages.find(l => l.code === selectedLanguage)?.name || selectedLanguage;

            document.getElementById('resultContainer').style.display = 'block';
            document.getElementById('resultContainer').innerHTML = `
                <div class="result-box">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5><i class="bi bi-check-circle text-success me-2"></i>Перевод готов</h5>
                    </div>

                    <div class="d-flex align-items-center mb-3">
                        <i class="bi bi-globe fs-3 me-3"></i>
                        <div>
                            <h6 class="mb-1">${escapeHtml(fullUrl)}</h6>
                           <small style="color: rgba(255,255,255,0.7);">Перевод на ${langName}</small>
                        </div>
                    </div>

                    <div class="d-grid gap-2">
                        <button class="btn btn-success btn-lg" onclick="openTranslation()">
                            <i class="bi bi-google me-2"></i>Открыть переведённую страницу
                        </button>
                        <button class="btn btn-outline-light" onclick="copyTranslatedUrl()">
                            <i class="bi bi-clipboard me-1"></i>Копировать URL перевода
                        </button>
                    </div>

                            <small style="color: rgba(255,255,255,0.7);" class="mt-3 d-block">
            <i class="bi bi-info-circle me-1"></i>
            Перевод откроется в новой вкладке через Google Translate
        </small>
                </div>
            `;

            document.getElementById('resultContainer').scrollIntoView({ behavior: 'smooth' });
        });

        function openTranslation() {
            const url = document.getElementById('websiteUrl').value.trim();
            let fullUrl = url;
            if (!fullUrl.startsWith('http://') && !fullUrl.startsWith('https://')) {
                fullUrl = 'https://' + fullUrl;
            }

            const translatedUrl = getTranslatedUrl(fullUrl, selectedLanguage);
            window.open(translatedUrl, '_blank');
        }

        function copyTranslatedUrl() {
            const url = document.getElementById('websiteUrl').value.trim();
            let fullUrl = url;
            if (!fullUrl.startsWith('http://') && !fullUrl.startsWith('https://')) {
                fullUrl = 'https://' + fullUrl;
            }
            const translatedUrl = getTranslatedUrl(fullUrl, selectedLanguage);

            navigator.clipboard.writeText(translatedUrl).then(() => {
                alert('✅ URL переведённой страницы скопирован!');
            }).catch(() => {
                prompt('Скопируйте URL:', translatedUrl);
            });
        }

        function escapeHtml(text) {
            const div = document.createElement('div');
            div.textContent = text;
            return div.innerHTML;
        }

        renderLanguages();
    </script>
</body>
</html>